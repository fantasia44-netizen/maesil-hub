# ─── Flask ───
SECRET_KEY=change-me-with-random-64-byte-hex

# ─── Supabase (hub 신규 프로젝트) ───
SUPABASE_URL=https://<new-ref>.supabase.co
SUPABASE_KEY=<anon-key>
SUPABASE_SERVICE_KEY=<service-role-key>
DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-0-ap-northeast-2.pooler.supabase.com:5432/postgres

# ─── 환경 모드 ───
APP_ENV=development         # development | staging | production
DEBUG=true

# ─── SaaS 모드 ───
SAAS_MODE=multi             # single | multi
DEFAULT_BIZ_ID=             # SAAS_MODE=single일 때만 사용

# ─── 결제 (Phase 1) ───
KAKAOPAY_ADMIN_KEY=
KAKAOPAY_CID=

# ─── 외부 API ───
CJ_CUST_ID=
NAVER_COMMERCE_CLIENT_ID=
NAVER_COMMERCE_CLIENT_SECRET=
COUPANG_VENDOR_ID=

# ─── 모니터링 ───
SENTRY_DSN=
